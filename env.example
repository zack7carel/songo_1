# =====================================================
# VARIABLES D'ENVIRONNEMENT
# Ne jamais committer ce fichier sur GitHub !
# Sur Render, ces valeurs sont configurées dans le dashboard
# =====================================================

# Clé secrète pour les sessions (changez-la !)
SESSION_SECRET=changez_cette_valeur_par_quelque_chose_de_long_et_aleatoire

# URL de la base PostgreSQL (fournie automatiquement par Render)
DATABASE_URL=postgresql://user:password@host/dbname

# Environnement
NODE_ENV=production
